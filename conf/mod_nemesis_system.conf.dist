#
# Nemesis System module configuration
#

[worldserver]

#
#    NemesisSystem.Enable
#        Description: Enables the Nemesis System module.
#        Default:     1 - enabled
#                     0 - disabled
#

NemesisSystem.Enable = 1

#
#    NemesisSystem.MaxRank
#        Description: Maximum rank a nemesis can reach.
#        Default:     5
#

NemesisSystem.MaxRank = 5

#
#    NemesisSystem.MinCreatureLevel
#        Description: Minimum creature level eligible to become a nemesis.
#        Default:     1
#

NemesisSystem.MinCreatureLevel = 1

#
#    NemesisSystem.MaxCreatureLevel
#        Description: Maximum creature level eligible to become a nemesis.
#        Default:     255
#

NemesisSystem.MaxCreatureLevel = 255

#
#    NemesisSystem.AllowNormal
#        Description: Allow normal-rank creatures to become nemeses.
#        Default:     1 - enabled
#                     0 - disabled
#

NemesisSystem.AllowNormal = 1

#
#    NemesisSystem.AllowElite
#        Description: Allow elite-rank creatures to become nemeses.
#        Default:     1 - enabled
#                     0 - disabled
#

NemesisSystem.AllowElite = 1

#
#    NemesisSystem.AllowRare
#        Description: Allow rare-rank creatures to become nemeses.
#        Default:     1 - enabled
#                     0 - disabled
#

NemesisSystem.AllowRare = 1

#
#    NemesisSystem.AllowRareElite
#        Description: Allow rare-elite creatures to become nemeses.
#        Default:     1 - enabled
#                     0 - disabled
#

NemesisSystem.AllowRareElite = 1

#
#    NemesisSystem.AllowWorldBoss
#        Description: Allow world-boss rank creatures to become nemeses.
#                     Dungeon and scripted bosses are still filtered separately.
#        Default:     0 - disabled
#

NemesisSystem.AllowWorldBoss = 0

#
#    NemesisSystem.RankUpCooldownSeconds
#        Description: Minimum time in seconds before the same creature can gain
#                     another nemesis promotion.
#        Default:     300
#

NemesisSystem.RankUpCooldownSeconds = 300

#
#    NemesisSystem.SameVictimCooldownSeconds
#        Description: Minimum time in seconds before the same player can feed
#                     another promotion to the same creature.
#        Default:     900
#

NemesisSystem.SameVictimCooldownSeconds = 900

#
#    NemesisSystem.PromotionLevelDiffMax
#        Description: Maximum absolute level difference allowed between the
#                     creature and the slain player for nemesis creation or
#                     rank-up.
#        Default:     5
#

NemesisSystem.PromotionLevelDiffMax = 5

#
#    NemesisSystem.TrivialKillLevelDelta
#        Description: Additional anti-trivial filter. If a creature is this
#                     many or more levels below the slain player, it cannot
#                     become or rank up as a nemesis.
#        Default:     5
#

NemesisSystem.TrivialKillLevelDelta = 5

#
#    NemesisSystem.DecayHours
#        Description: Deletes inactive nemesis state after this many hours.
#                     Set to 0 to disable decay.
#        Default:     48
#

NemesisSystem.DecayHours = 48

#
#    NemesisSystem.RevengeRewardItem
#        Description: Optional item reward granted when the original target or
#                     their party kills the nemesis.
#        Default:     0 - disabled
#

NemesisSystem.RevengeRewardItem = 0

#
#    NemesisSystem.RevengeRewardCount
#        Description: Count for the revenge reward item.
#        Default:     1
#

NemesisSystem.RevengeRewardCount = 1

#
#    NemesisSystem.RevengeRewardItemPerRankBonus
#        Description: Additional item count granted per rank above rank 1.
#        Default:     0
#

NemesisSystem.RevengeRewardItemPerRankBonus = 0

#
#    NemesisSystem.RevengeRewardGold
#        Description: Gold reward in copper for revenge kills.
#        Default:     10000
#

NemesisSystem.RevengeRewardGold = 10000

#
#    NemesisSystem.RevengeRewardGoldPerRankBonus
#        Description: Additional copper granted per rank above rank 1.
#        Default:     2500
#

NemesisSystem.RevengeRewardGoldPerRankBonus = 2500

#
#    NemesisSystem.BountyRewardItem
#        Description: Optional item reward granted when another player kills a
#                     nemesis that targets someone else.
#        Default:     0 - disabled
#

NemesisSystem.BountyRewardItem = 0

#
#    NemesisSystem.BountyRewardCount
#        Description: Count for the bounty reward item.
#        Default:     1
#

NemesisSystem.BountyRewardCount = 1

#
#    NemesisSystem.BountyRewardItemPerRankBonus
#        Description: Additional item count granted per rank above rank 1.
#        Default:     0
#

NemesisSystem.BountyRewardItemPerRankBonus = 0

#
#    NemesisSystem.BountyRewardGold
#        Description: Gold reward in copper for bounty kills.
#        Default:     2500
#

NemesisSystem.BountyRewardGold = 2500

#
#    NemesisSystem.BountyRewardGoldPerRankBonus
#        Description: Additional copper granted per rank above rank 1.
#        Default:     500
#

NemesisSystem.BountyRewardGoldPerRankBonus = 500

#
#    NemesisSystem.RewardOverlevelDiffMax
#        Description: Maximum positive level difference between the highest
#                     eligible nearby reward recipient and the nemesis before
#                     rewards scale down to zero.
#        Default:     10
#

NemesisSystem.RewardOverlevelDiffMax = 10

#
#    NemesisSystem.RewardUnderlevelDiffMax
#        Description: Maximum negative level difference used to scale rewards
#                     upward when the highest eligible nearby reward recipient
#                     is below the nemesis level.
#        Default:     10
#

NemesisSystem.RewardUnderlevelDiffMax = 10

#
#    NemesisSystem.RewardUnderdogMaxMultiplier
#        Description: Maximum reward multiplier reached when the highest
#                     eligible nearby reward recipient is at least
#                     RewardUnderlevelDiffMax levels below the nemesis.
#        Default:     2.0
#

NemesisSystem.RewardUnderdogMaxMultiplier = 2.0

#
#    NemesisSystem.EnragedHealthPctThreshold
#        Description: Health percentage at or below which the Enraged affix becomes active.
#        Default:     30.0
#

NemesisSystem.EnragedHealthPctThreshold = 30.0

#
#    NemesisSystem.EnragedDamageMultiplier
#        Description: Damage multiplier applied while the Enraged affix is active.
#        Default:     1.50
#

NemesisSystem.EnragedDamageMultiplier = 1.50

#
#    NemesisSystem.RegenerationIntervalMs
#        Description: Tick interval in milliseconds for the Regenerating affix.
#        Default:     5000
#

NemesisSystem.RegenerationIntervalMs = 5000

#
#    NemesisSystem.RegenerationHealthPct
#        Description: Percent of max health restored each regeneration tick.
#        Default:     3.0
#

NemesisSystem.RegenerationHealthPct = 3.0

#
#    NemesisSystem.AnnounceOnCreate
#        Description: Sends nemesis creation and rank-up announcements to the
#                     nemesis zone. Reaching rank 5 is announced server-wide.
#        Default:     1 - enabled
#                     0 - disabled
#

NemesisSystem.AnnounceOnCreate = 1

#
#    NemesisSystem.AnnounceOnKill
#        Description: Sends nemesis kill announcements to the nemesis zone.
#        Default:     1 - enabled
#                     0 - disabled
#

NemesisSystem.AnnounceOnKill = 1

#
#    NemesisSystem.AnnounceMinRank
#        Description: Minimum nemesis rank required before announcements are sent.
#        Default:     1
#

NemesisSystem.AnnounceMinRank = 1

#
#    NemesisSystem.VisualAuraSpell
#        Description: Optional aura spell applied to active nemeses.
#                     Set to 0 to disable the visual aura.
#        Default:     0
#

NemesisSystem.VisualAuraSpell = 0

#
#    NemesisSystem.AddonBootstrapRecentHours
#        Description: Recent nemeses within this many hours are included in
#                     player addon bootstrap responses, alongside rank 5 and
#                     relation-matched nemeses.
#        Default:     24
#

NemesisSystem.AddonBootstrapRecentHours = 24

#
#    NemesisSystem.AddonBootstrapMaxEntries
#        Description: Maximum number of nemesis entries sent in a filtered
#                     player addon bootstrap response.
#        Default:     100
#

NemesisSystem.AddonBootstrapMaxEntries = 100

#
#    NemesisSystem.AddonReportCooldownSeconds
#        Description: Minimum time between validated addon sighting updates for
#                     the same nemesis spawn.
#        Default:     30
#

NemesisSystem.AddonReportCooldownSeconds = 30